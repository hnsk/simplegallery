{% extends "base.html.j2" %}
{% block title %}{{ site_title }}{% endblock %}
{% block body %}
<header class="site-header">
  <h1>{{ site_title }}</h1>
</header>
<main>
  <ul class="gallery-grid index-grid">
    {% for entry in galleries %}
    <li class="index-card">
      <a href="{{ entry.href }}">
        {% if entry.cover_thumb %}
        <img src="{{ entry.cover_thumb }}" alt="{{ entry.name }}" loading="lazy">
        {% endif %}
        <h2>{{ entry.name }}</h2>
        <p class="count">{{ entry.count }} item{{ '' if entry.count == 1 else 's' }}</p>
      </a>
    </li>
    {% endfor %}
  </ul>
</main>
{% endblock %}
